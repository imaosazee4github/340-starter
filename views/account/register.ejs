<h1><%= title %></h1>

<%- messages() %>
<% if (erros) { %>
<ul class="notice">
    <% errors.array().forEach(error => { %>
        <li><%= error.mssg %></li>
    <% }) %>
</ul>
<% } %>
<div class="form-container">
<form action="/account/register" method="post" class="login-form" novalidate>

<div class="form-group">
<label for="account_firstname">First Name</label>
<input type="text"  name="account_firstname" id="account_firstname" required value="<%= laccount_firstname %>">
</div>

<div class="form-group">
<label for="account_lastname">Last Name</label>
<input type="text" name="account_lastname" id="account_lastname" required value="<%= account_lastname %>">
</div>

<div class="form-group">
<label for="account_email">Email</label>
<input type="email" name="account_email" id="account_email" required value="<%= account_email %>">
</div>

<div class="form-group">
<label for="account_password">Password</label>
<div class="password-wrapper">
<input
type="password"
name="account_password"
id="account_password"
required
minlength="12"
pattern="(?=.*[A-Z])(?=.*[0-9])(?=.*[^A-Za-z0-9]).{12,}"
title="Must be at least 12 characters, include 1 uppercase letter, 1 number, and 1 special character">
<span id="togglePassword" class="toggle-password">show👁</span>
</div>
</div>

<button type="submit" class="btn">Register</button>

</form>
</div>