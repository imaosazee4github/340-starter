<header id="top-header">
<span class="siteName">
    <a href="/" title="Return to home page">CSE Motors</a>
</span>
<div id="tools">
    <% if (locals.loggedIn) { %>
        
    <a href="/account/" title="Go to account dashboard">
        Welcome <%= locals.accountData?.account_firstname %>
    </a>
    |
    <a href="/account/logout" title="Logout">Logout</a>
    
      <% } else { %>

      <a href="/account/login" title="Click to log in">My Account</a>
      |
      <a href="/account/register" title="Create account">Register</a>
    <% } %>
</div>
</header>