<h1><%= title %></h1>

<% console.log('=== add-classification.ejs loaded ===') %>
<% console.log('errors type:', typeof errors) %>
<% console.log('errors value:', errors) %>
<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<p>Classification name must not contain spaces or special characters.</p>

<form action="/inv/add-classification" method="post">

  <div class="form-group">
    <label for="classification_name">Classification Name</label>
    <input 
      type="text" 
      name="classification_name" 
      id="classification_name" 
      required
      pattern="^[A-Za-z0-9]+$"
      title="No spaces or special characters allowed"
      value="<%= locals.classification_name %>"
    >
  </div>

  <button type="submit">Add Classification</button>

</form>
