<h1><%= title %></h1>

<%- messages() %>

<%
let errorMessages = [];
if (errors) {
  if (Array.isArray(errors)) {
    errorMessages = errors;
  } else if (errors.array && typeof errors.array === 'function') {
    errorMessages = errors.array();
  }
}
%>

<% if (errorMessages.length > 0) { %>
  <ul class="notice">
    <% errorMessages.forEach(error => { %>
      <li><%= error.msg || error %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/inv/update" method="post" id="updateForm">

  
  <input type="hidden" name="inv_id" value="<%= inv_id %>">

  <div class="form-group">
    <label for="classification_id">Classification</label>
    <%- classificationSelect %>
  </div>

  <div class="form-group">
    <label for="inv_make">Make</label>
    <input type="text" name="inv_make" id="inv_make" required 
           value="<%= inv_make %>">
  </div>

  <div class="form-group">
    <label for="inv_model">Model</label>
    <input type="text" name="inv_model" id="inv_model" required 
           value="<%= inv_model %>">
  </div>

  <div class="form-group">
    <label for="inv_year">Year</label>
    <input type="number" name="inv_year" id="inv_year" required 
           value="<%= inv_year %>">
  </div>

  <div class="form-group">
    <label for="inv_description">Description</label>
    <textarea name="inv_description" id="inv_description" required><%= inv_description %></textarea>
  </div>

  <div class="form-group">
    <label for="inv_image">Image Path</label>
    <input type="text" name="inv_image" id="inv_image" 
           value="<%= inv_image %>">
  </div>

  <div class="form-group">
    <label for="inv_thumbnail">Thumbnail Path</label>
    <input type="text" name="inv_thumbnail" id="inv_thumbnail" 
           value="<%= inv_thumbnail %>">
  </div>

  <div class="form-group">
    <label for="inv_price">Price</label>
    <input type="number" name="inv_price" id="inv_price" required step="0.01" 
           value="<%= inv_price %>">
  </div>

  <div class="form-group">
    <label for="inv_miles">Miles</label>
    <input type="number" name="inv_miles" id="inv_miles" required 
           value="<%= inv_miles %>">
  </div>

  <div class="form-group">
    <label for="inv_color">Color</label>
    <input type="text" name="inv_color" id="inv_color" required 
           value="<%= inv_color %>">
  </div>

  <button type="submit">Update Vehicle</button>
  <input type="hidden" name="inv_id"
<% if (locals.inv_id) { %> value="<%= locals.inv_id %>"
<% } %>>

</form>

<script src="../../public/js/inv-update.js"></script>